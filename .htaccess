RewriteEngine On

# 🔒 Bloquear pastas sensíveis
RewriteRule ^(app|config)(/|$) - [F,L]

# 🚫 Evitar loop com /public
RewriteCond %{REQUEST_URI} !^/public/

# 🎯 Acessar /painel-admin sem /public
RewriteRule ^painel-admin/(.*)$ public/painel-admin/$1 [L]

# 🌐 Demais arquivos vão para /public
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public/$1 [L]

# 🧭 Raiz do site
RewriteRule ^$ public/ [L]